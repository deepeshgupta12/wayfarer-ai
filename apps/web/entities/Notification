{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "alert",
        "recommendation",
        "insight",
        "reminder",
        "update"
      ]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "action_url": {
      "type": "string"
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "trip_id": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium"
    }
  },
  "required": [
    "user_email",
    "title",
    "body"
  ]
}